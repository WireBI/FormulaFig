{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://formulafig-production.up.railway.app/api/:path*"
    }
  ]
}
